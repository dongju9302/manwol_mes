# Docker 빌드 컨텍스트에서 제외할 파일 목록
# 빌드 속도 향상 + 이미지에 불필요한/민감한 파일 포함 방지

# 의존성 (컨테이너 안에서 npm install 로 재설치)
node_modules

# 빌드 산출물 (컨테이너 안에서 next build 로 재생성)
.next

# 버전 관리
.git
.gitignore

# 문서
README.md

# 로컬 전용 환경변수 (프로덕션 환경변수는 별도 주입)
.env.local
.env*.local

# 에디터 설정
.vscode
.idea

# 로그
*.log

# macOS 메타데이터
.DS_Store
