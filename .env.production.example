# Docker Compose 환경에서 사용하는 환경변수 템플릿
# 이 파일을 복사해 .env.production 을 만들고 실제 값을 채워넣을 것
# .env.production 은 git 에 커밋하지 않음

# ── PostgreSQL 컨테이너 환경변수 ──────────────────────────────────
# docker-compose.yml 의 db 서비스에서 직접 참조
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=

# ── Next.js 앱 환경변수 ───────────────────────────────────────────
# POSTGRES_USER, POSTGRES_PASSWORD, POSTGRES_DB 와 일치해야 함
# host 는 docker-compose.yml 의 DB 서비스명 (기본값: db)
DATABASE_URL=postgresql://POSTGRES_USER:POSTGRES_PASSWORD@db:5432/POSTGRES_DB

# JWT 서명 비밀키 (최소 64바이트 이상의 랜덤 문자열 권장)
JWT_SECRET=
